---
import type { CardDeviceListType } from "../types/deviceTypes";
import CardDevice from "./CardDevice.astro";

interface Props {
  cardList: CardDeviceListType;
}

const { cardList } = Astro.props;
---

<ul class="card-list-container">
  {
    cardList.map((card) => (
      <li>
        <CardDevice card={card} />
      </li>
    ))
  }
</ul>

<style>
  .card-list-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(300px, 100%), 1fr));
    gap: 3rem;
  }
</style>
