---
import Button from "../../../components/Button.astro";
import type { DeviceAddSchemaType } from "../types/deviceTypes";

type Props = {
  response: { message: string; code: string } | null;
  values: DeviceAddSchemaType;
};

const { response, values } = Astro.props;
---

<form method="POST">
  <fieldset name="form-add-device">
    <legend>Add device schema form</legend>
    <div class="form-group">
      <label for="name">Device name</label>
      <input type="text" id="name" name="name" value={values?.name} />
      <p class="message-error" id="name-error"></p>
    </div>
    <div class="form-group">
      <label for="mac">Mac address</label>
      <input type="text" id="mac" name="mac" value={values?.mac} />
      <p class="message-error" id="mac-error"></p>
    </div>
    <div class="form-group">
      <label for="ip">IP address</label>
      <input type="text" id="ip" name="ip" value={values?.ip} />
      <p class="message-error" id="ip-error"></p>
    </div>
    <div class="form-group">
      <Button text="Add device" type="submit" />
      {
        response ? (
          <p
            class={response.code === "SUCCESS" ? "message-success" : "message-error"}
            id="form-error"
          >
            {response.message}
          </p>
        ) : null
      }
    </div>
  </fieldset>
</form>

<script>
  import { handleForm } from "../../../utils/utils";
  import { DeviceAddSchema } from "../schemas/deviceSchemas";

  const form = document.querySelector("form");

  if (form instanceof HTMLFormElement) {
    handleForm(form, DeviceAddSchema);
  }
</script>

<style>
  form {
    max-width: 300px;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  legend {
    visibility: hidden;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  input {
    padding: 0.5rem;
    border: 1px solid black;
  }
</style>
