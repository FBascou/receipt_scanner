---
import ButtonLink from "../components/ButtonLink.astro";
import ToggleColorTheme from "../components/ToggleColorTheme.astro";
import Navbar from "./Navbar.astro";
---

<header>
  <div class="link-skip-header">
    <ButtonLink href={"#main"} text="Skip to content" />
  </div>
  <a class="link-logo" href="/"><img src="" alt="RecScan" /></a>
  <ToggleColorTheme />
  <Navbar />
</header>

<style>
  header {
    position: sticky;
    top: 0;
    left: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 60px;
    width: 100%;
    background-color: var(--bg);
    box-shadow: var(--box-shadow);
    z-index: 10;
  }

  .link-skip-header {
    position: absolute;
    display: inline-block;
    left: 50%;
    padding: 1rem;
    line-height: 1;
    background-color: var(--bg-accent);
    color: var(--clr);
    transform: translateY(-5rem);
    opacity: 0;
    transition:
      transform 0.3s ease-in,
      opacity 0.3s ease-in;
    z-index: 20;
  }

  .link-skip-header:focus,
  .link-skip-header:focus-visible {
    transform: translateY(0);
    opacity: 1;
  }
</style>
