---
interface Props {
  title?: string;
  direction?: string;
}

const { title, direction = "column" } = Astro.props;
---

<section>
  {title ? <h2>{title}</h2> : null}
  <div class="section-content">
    <slot />
  </div>
</section>

<style define:vars={{ direction }}>
  section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .section-content {
    width: 100%;
    display: flex;
    flex-direction: var(--direction);
    gap: 1rem;
  }
</style>
