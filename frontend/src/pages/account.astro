---
import Layout from "../layouts/Layout.astro";
import FormUpdateAccount from "../features/users/components/FormUpdateAccount.astro";

export const prerender = false;
const user = Astro.locals.user;

let errorMessage: string | null = null;
let values: UpdateAccountSchemaType = {
  email: user?.email,
  password: "",
  confirm: "",
};

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  values = Object.fromEntries(data) as UpdateAccountSchemaType;

  const result = await getUpdateUserAction(values, Astro);

  if (result instanceof Response) {
    return result;
  }

  errorMessage = result?.message ?? null;
}
---

<Layout title="Update">
  <h1>Update account</h1>
  <FormUpdateAccount errorMessage={errorMessage} values={values} />
</Layout>
