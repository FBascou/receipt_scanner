---
import ButtonLink from "../../components/ButtonLink.astro";
import CardDeviceList from "../../features/devices/components/CardDeviceList.astro";
import Layout from "../../layouts/Layout.astro";
import { requestApi } from "../../lib/requestApi";

export const prerender = false;

let errorMessage = null;

const result = await requestApi(Astro, "/api/v1/devices/", {
  headers: {
    "Content-Type": "application/json",
  },
  method: "GET",
});

const deviceList = await result.json();

if (!result.ok) {
  errorMessage = result?.details?.error?.message ?? result?.message ?? null;
}

console.log("GET", deviceList);
---

<Layout title="Devices">
  <h1>Devices</h1>
  {
    !deviceList.total ? (
      <div>
        <p>There are no devices available</p>
        <ButtonLink style="secondary" href="/devices/add-device" text="Add new device" />
      </div>
    ) : (
      <CardDeviceList cardList={deviceList?.items} />
    )
  }
