---
import CardList from "../components/CardList.astro";
import ChartLine from "../components/ChartLine.astro";
import { getUserOverview } from "../features/users/api/userApi";
import type { UserOverview } from "../features/users/types/userTypes";
import Layout from "../layouts/Layout.astro";
import Section from "../layouts/Section.astro";
import { requireUser } from "../lib/auth/requireUser";

export const prerender = false;

type CardType = {
  id: number;
  title: string;
  value: number | string;
};

const user = requireUser(Astro);

let result = null;

if (user) {
  try {
    // TODO:
    // Create a typed return for getUserOverview
    // Create a postAddDevice
    // Something wrong with the total amount receipts
    result = await getUserOverview(Astro);
  } catch (error) {}
}

// If multiple devices connected, then receipts scanned in device 1, device n... receipt amount in device 1, device n...
const overviewCards: CardType[] = [
  {
    id: 0,
    title: "Devices connected",
    value: result?.[1]?.devices ?? 0,
  },
  {
    id: 1,
    title: "Uploads made",
    value: result?.[1]?.job_count ?? 0,
  },
  {
    id: 2,
    title: "Receipts scanned",
    value: result?.[1]?.receipt_count ?? 0,
  },
  {
    id: 3,
    title: "Total receipt amount",
    value: result?.[1]?.receipt_amount ?? 0,
  },
];
---

<Layout title="Dashboard">
  <h1>Dashboard</h1>
  <Section title="Overview">
    <CardList size="s" cardList={overviewCards} />
  </Section>
  <Section title="Total sales" direction="row">
    <ChartLine id="total-sales" />
    <ChartLine id="total-receipts" />
  </Section>
</Layout>
